# Copiar este archivo como `.env` y rellenar los valores reales.
# El archivo `.env` está en .gitignore — NUNCA lo commitees.

# ====== Base de datos (Postgres en Docker) ======
DB_USER=changeme_db_user
DB_PASSWORD=changeme_db_password_strong
DB_NAME=gestion_lotes

# Connection string usada por backend y Prisma.
# Debe coincidir con los valores de arriba; el host es `db` (servicio Docker).
DATABASE_URL=postgresql://changeme_db_user:changeme_db_password_strong@db:5432/gestion_lotes

# ====== Auth ======
# Generar con: openssl rand -base64 32   (o `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`)
# Ambos deben tener al menos 16 caracteres; en producción usar 32+.
JWT_SECRET=changeme_generate_with_openssl_rand_base64_32
JWT_REFRESH_SECRET=changeme_generate_a_different_secret_here

# Opcionales (tienen defaults razonables en el código)
# JWT_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d
# BCRYPT_SALT_ROUNDS=12
# LOGIN_RATE_LIMIT=10

# ====== Entorno ======
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ====== Frontend ======
VITE_API_URL=http://localhost:4000
